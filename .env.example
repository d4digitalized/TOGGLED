# Zkopíruj jako .env.local a doplň hodnoty ze Supabase (Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
# Service role / secret — NIKDY neposílat do prohlížeče, jen server (pozvánky)
SUPABASE_SERVICE_ROLE_KEY=eyJ...
# Veřejná URL aplikace (na Vercelu produkční doména)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# (v2) Resend — odesílání e-mailů z kódu, jen server, bez NEXT_PUBLIC_
# Pozvánky ho NEpotřebují (ty jdou přes Supabase SMTP nastavené v dashboardu)
# RESEND_API_KEY=re_...
